# Address the HTTP server binds to.
BIND_ADDR=0.0.0.0:8080

# Redis connection URL.
REDIS_URL=redis://127.0.0.1:6379

# Tracing filter — see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=info,dinglebop=debug

# pretty | json
LOG_FORMAT=pretty

# Optional: stable identifier for this instance. Defaults to a random UUID per process.
# INSTANCE_ID=

# Comma-separated CORS origin allow-list. Leave empty in production
# (same-origin via ingress). For local dev (frontend on :8000, backend on
# :8080), allow the dev origin.
CORS_ALLOWED_ORIGINS=http://localhost:8000
